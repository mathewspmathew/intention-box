{
  "expo": {
    "name": "Intention Box",
    "slug": "intention-box",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "intentionbox",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.intentionbox.app"
    },
    "android": {
      "package": "com.intentionbox.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1A1A1A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#C9A84C"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TodayWidget",
              "label": "Today's Intentions",
              "description": "Shows today's active intentions",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "resizeMode": "none",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
